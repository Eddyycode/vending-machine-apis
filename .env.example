# ==============================================================
# VENDING MACHINE E-COMMERCE — Variables de Entorno
# Copia este archivo a .env y llena tus valores reales.
# NUNCA commitees .env a git.
# ==============================================================

# --- Supabase ---
# Encuéntralos en: Supabase Dashboard → Settings → API
SUPABASE_URL=https://TU_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Database (Supabase connection string async) ---
# Encuéntrala en: Supabase Dashboard → Settings → Database → Connection string (selecciona URI)
# Añade ?ssl=require al final
DATABASE_URL=postgresql+asyncpg://postgres:TU_PASSWORD@db.TU_PROJECT_ID.supabase.co:5432/postgres?ssl=require

# --- App ---
APP_ENV=development          # development | production
APP_VERSION=0.1.0
SECRET_KEY=cambia-esto-por-una-clave-segura-de-al-menos-32-chars

# --- Pagos (Stripe - modo sandbox) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- CORS (orígenes permitidos, separados por coma) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
